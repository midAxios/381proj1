-- jalr in RISC-V

-- rd = pc + 4
--	 pc = rs1 + imm

-- 03/05/26 Ivy Creech

library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity jalr is
    Port (
        pc       : in  STD_LOGIC_VECTOR(31 downto 0); -- current PC
        rs1      : in  STD_LOGIC_VECTOR(31 downto 0); -- base register
        imm      : in  STD_LOGIC_VECTOR(11 downto 0); -- 12-bit immediate
        rd       : out STD_LOGIC_VECTOR(31 downto 0); -- destination register for PC+4
        pc_next  : out STD_LOGIC_VECTOR(31 downto 0)  -- next PC value
    );
end jalr;

architecture Behavioral of jalr is
    signal imm_ext   : STD_LOGIC_VECTOR(31 downto 0);
    signal temp_pc   : STD_LOGIC_VECTOR(31 downto 0);
    signal pc_plus4  : STD_LOGIC_VECTOR(31 downto 0);
begin

    -- Sign extend the 12-bit immediate
    imm_ext <= std_logic_vector(resize(signed(imm), 32));

    -- Compute PC + 4 for return address
    pc_plus4 <= std_logic_vector(unsigned(pc) + 4);
    rd <= pc_plus4;

    -- Compute next PC = (rs1 + imm) & ~1
    temp_pc <= std_logic_vector(unsigned(rs1) + unsigned(imm_ext));
    pc_next <= temp_pc(31 downto 1) & '0';  -- clear LSB

end Behavioral;