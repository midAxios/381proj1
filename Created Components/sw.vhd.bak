library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity sw is
    Port (
        rs1       : in  STD_LOGIC_VECTOR(31 downto 0);  -- base register
        rs2       : in  STD_LOGIC_VECTOR(31 downto 0);  -- data to store
        imm       : in  STD_LOGIC_VECTOR(11 downto 0);  -- 12-bit immediate
        address   : out STD_LOGIC_VECTOR(31 downto 0);  -- calculated memory address
        mem_data  : out STD_LOGIC_VECTOR(31 downto 0)   -- data written to memory
    );
end sw;

architecture Behavioral of sw is
    signal imm_ext : STD_LOGIC_VECTOR(31 downto 0);
begin

    -- Sign extend the immediate to 32 bits
    imm_ext <= std_logic_vector(resize(signed(imm), 32));

    -- Calculate memory address
    address <= std_logic_vector(unsigned(rs1) + unsigned(imm_ext));

    -- Data to be stored in memory
    mem_data <= rs2;

end Behavioral;