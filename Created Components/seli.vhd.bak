-- srli in RISC-V

-- 03/05/26 Ivy Creech 

library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity srli is
    Port (
        rs1  : in  STD_LOGIC_VECTOR(31 downto 0);  -- value to shift
        imm  : in  STD_LOGIC_VECTOR(11 downto 0);  -- 12-bit I-type immediate
        rd   : out STD_LOGIC_VECTOR(31 downto 0)   -- result
    );
end srli;

architecture Behavioral of srli is
begin

    -- Shift left logical by immediate
    rd <= std_logic_vector(shift_right(unsigned(rs1), to_integer(unsigned(imm))));

end Behavioral;