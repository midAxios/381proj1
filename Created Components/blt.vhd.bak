-- blt in RISC-V
-- if ( rs1 < rs2){
--	goto branch;
-- }

-- blt rs1, rs2, branch
--	pc = pc + imm

-- 03/05/26 Ivy Creech

library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity blt is
    Port (
        rs1     : in  STD_LOGIC_VECTOR(31 downto 0); -- first register
        rs2     : in  STD_LOGIC_VECTOR(31 downto 0); -- second register
        pc      : in  STD_LOGIC_VECTOR(31 downto 0); -- current PC
        imm     : in  STD_LOGIC_VECTOR(11 downto 0); -- branch immediate
        next_pc : out STD_LOGIC_VECTOR(31 downto 0); -- next PC value
        branch  : out STD_LOGIC                      -- branch signal
    );
end blt;

architecture Behavioral of blt is
    signal imm_ext : STD_LOGIC_VECTOR(31 downto 0);
begin

    -- Sign extend the immediate
    imm_ext <= std_logic_vector(resize(signed(imm), 32));

    process(rs1, rs2, pc, imm_ext)
    begin
        if signed(rs1) < signed(rs2) then
            branch <= '1';
            next_pc <= std_logic_vector(unsigned(pc) + unsigned(imm_ext));
        else
            branch <= '0';
            next_pc <= std_logic_vector(unsigned(pc) + 4);
        end if;
    end process;

end Behavioral;